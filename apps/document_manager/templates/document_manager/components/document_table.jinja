<div class="card bg-base-100 shadow">

    <div class="card-body p-0">

        <table class="table w-full">

            <thead>

                <tr>
                    <th>Name</th>
                    <th>Nodes</th>
                    <th>Edges</th>
                    <th>Relations</th>
                    <th>LLM</th>
                    <th>Processing Time</th>
                </tr>

            </thead>

            <tbody>

                {% for doc in documents %}

                <tr>

                    <td class="font-medium">
                        {{ doc.name }}
                    </td>

                    <td>
                        {{ doc.nodes }}
                    </td>

                    <td>
                        {{ doc.edges }}
                    </td>

                    <td>
                        {{ doc.relations }}
                    </td>

                    <td>
                        {{ doc.llm_used }}
                    </td>

                    <td>

                        {% if doc.processing_time %}
                            {{ doc.processing_time }} s
                        {% else %}
                            -
                        {% endif %}

                    </td>

                </tr>

                {% endfor %}

            </tbody>

        </table>

    </div>

</div>