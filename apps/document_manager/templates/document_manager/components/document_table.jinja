<div class="card bg-base-100 shadow">

    <div class="card-body p-0 overflow-x-auto">

        <table class="table w-full min-w-[1100px]">

            <thead>

                <tr>
                    <th>Name</th>
                    <th>Nodes</th>
                    <th>Edges</th>
                    <th>Relations</th>
                    <th>LLM</th>
                    <th>Estimated Tokens</th>
                    <th>Processing Time</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>

            </thead>

            <tbody>

                {% for doc in documents %}

                <tr>

                    <td class="font-medium">{{ doc.name }}</td>
                    <td> {{ doc.nodes }} </td>
                    <td> {{ doc.edges }} </td>
                    <td> {{ doc.relations }} </td>
                    <td> {{ doc.llm_used }} </td>
                    <td>
                        {% if doc.estimated_tokens %}
                            {{ "{:,}".format(doc.estimated_tokens) }}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>
                        {% if doc.processing_time %}
                            {{ "%.2f"|format(doc.processing_time) }} s
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>
                        {% if doc.status == "pending" %}
                            <span class="badge badge-warning">Pending</span>
                        {% elif doc.status == "processing" %}
                            <div class="w-40">
                                <progress
                                    class="progress progress-primary w-full"
                                    value="{{ doc.progress }}"
                                    max="100"
                                ></progress>
                                <div class="mt-1 text-xs opacity-70">
                                    {{ doc.progress }}%
                                </div>
                            </div>
                        {% elif doc.status == "complete" %}
                            <span class="badge badge-success">Complete</span>
                        {% elif doc.status == "error" %}
                            <span class="badge badge-error">Error</span>
                        {% endif %}
                    </td>
                    <td class="space-x-2">
                        <button class="btn btn-sm btn-primary" 
                            hx-post="{{url('document_manager:process_document', args=[doc.id])}}" 
                            hx-swap="none" {% if doc.status == "processing" %}disabled{% endif %} >
                            Process
                        </button>
                        <button class="btn btn-sm btn-error" 
                                hx-delete="{{url('document_manager:delete_document', args=[doc.id])}}" 
                                hx-swap="none" {% if doc.status == "processing" %}disabled{% endif %} > 
                            Delete 
                        </button>
                        {% if doc.status == "complete" %}
                                <a
                                class="btn btn-sm btn-outline"
                                href="{{ url('document_manager:qa_sessions', kwargs={'doc_id': doc.id}) }}">
                                Open QA
                                </a>
                        {% else %}
                            <span
                                class="btn btn-sm btn-disabled opacity-60 cursor-not-allowed"
                                title="Process the document before opening QA"
                            >
                                Open QA
                            </span>
                        {% endif %}
                        <a
                            class="btn btn-sm btn-ghost"
                            href="{{ url('document_manager:document_logs', kwargs={'doc_id': doc.id}) }}"
                        >
                            Logs
                        </a>
                    </td>
                </tr>
                {% endfor %}

            </tbody>

        </table>

    </div>

</div>