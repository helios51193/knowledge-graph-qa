<div class="card bg-base-100 shadow">

    <div class="card-body p-0">

        <table class="table w-full">

            <thead>

                <tr>
                    <th>Name</th>
                    <th>Nodes</th>
                    <th>Edges</th>
                    <th>Relations</th>
                    <th>LLM</th>
                    <th>Processing Time</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>

            </thead>

            <tbody>

                {% for doc in documents %}

                <tr>

                    <td class="font-medium">{{ doc.name }}</td>
                    <td> {{ doc.nodes }} </td>
                    <td> {{ doc.edges }} </td>
                    <td> {{ doc.relations }} </td>
                    <td> {{ doc.llm_used }} </td>
                    <td>
                        {% if doc.processing_time %}
                            {{ doc.processing_time }} s
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>
                        {% if doc.status == "pending" %}
                            <span class="badge badge-warning">Pending</span>
                        {% elif doc.status == "processing" %}
                            <progress class="progress progress-primary w-24"></progress>
                        {% elif doc.status == "complete" %}
                            <span class="badge badge-success">Complete</span>
                        {% elif doc.status == "error" %}
                            <span class="badge badge-error">Error</span>
                        {% endif %}
                    </td>
                    <td class="space-x-2">
                        <button class="btn btn-sm btn-primary" hx-post="{{url('document_manager:process_document', args=[doc.id])}}" hx-swap="none">
                            Process
                        </button>
                        <button class="btn btn-sm btn-error" hx-delete="{{url('document_manager:delete_document', args=[doc.id])}}" hx-swap="none" > 
                            Delete 
                        </button>
                        <a  class="btn btn-sm btn-primary" href="{{ url('document_manager:qa_page', kwargs={'doc_id':doc.id }) }}" > Open QA </a>
                    </td>

                </tr>

                {% endfor %}

            </tbody>

        </table>

    </div>

</div>