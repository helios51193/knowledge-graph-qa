<dialog id="upload-modal" class="modal modal-open">

    <div class="modal-box">

        <h3 class="font-bold text-lg mb-6">
            Upload Document
        </h3>

        <form
            hx-post="{{url('document_manager:upload_document')}}"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            enctype="multipart/form-data"
            class="space-y-4">
            {% if form.errors %}
                <div class="alert alert-error">
                    <ul class="text-sm">
                        {% for field, errors in form.errors.items() %}
                            {% for error in errors %}
                                <li>{{ error }}</li>
                            {% endfor %}
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            <fieldset class="fieldset">
                <legend class="fieldset-legend">Document Name</legend>
                {{form.name}}

                <legend class="fieldset-legend">Select File (.pdf, .md, .txt)</legend>
                {{form.file}}

                <legend class="fieldset-legend">Select LLM to use</legend>
                {{form.llm_used}}

            </fieldset>
            <div class="modal-action">

                <button type="submit" class="btn btn-primary">
                    Upload
                </button>

                <button
                    type="button"
                    class="btn"
                    onclick="document.getElementById('upload-modal').remove()"
                >
                    Cancel
                </button>

            </div>

        </form>

    </div>

</dialog>