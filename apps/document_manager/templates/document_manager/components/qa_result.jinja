<div class="chat chat-end">
    <div class="chat-bubble chat-bubble-primary">
        {{ question }}
    </div>
</div>

<div class="chat chat-start">
    <div class="chat-bubble bg-base-200 text-base-content max-w-full">
        {% if has_error %}
        <div class="text-error font-medium">Error</div>
        <div class="mt-1">{{ answer }}</div>
        {% else %}
        <div>{{ answer }}</div>
        {% endif %}
        {% if cypher or rows or provenance %}
            <div class="mt-3">
            <button
                type="button"
                class="btn btn-xs btn-outline"
                onclick="openAnswerExplainModal(this)"
            >
                Explain Answer
            </button>

            <script type="application/json" class="qa-explain-data">
                {{ {
                    "cypher": cypher,
                    "rows": rows,
                    "provenance": provenance
                } | tojson }}
            </script>
    </div>
{% endif %}
    </div>
</div>