<div id="graph-panel-container">
    <section class="card border border-base-300 bg-base-100 shadow-sm h-[78vh] min-h-[78vh]">
        <div class="card-body flex h-full min-h-0 flex-col">
            <div class="mb-4 flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold">Graph View</h2>
                    <p class="text-sm opacity-70">
                        Visual graph for this document
                    </p>
                    <p class="mt-1 text-xs opacity-60">
                        {{ document.nodes }} nodes · {{ document.edges }} edges
                    </p>
                </div>

                <div class="flex flex-wrap justify-end gap-2">
                    <button
                        type="button"
                        class="btn btn-sm btn-ghost"
                        hx-get="{{ url('document_manager:graph_panel', kwargs={'doc_id': document.id}) }}"
                        hx-target="#graph-panel-container"
                        hx-swap="outerHTML"
                    >
                        Reload
                    </button>
                    <button id="rehighlight-graph-btn" type="button" class="btn btn-sm btn-outline">
                        Rehighlight
                    </button>
                    <button id="reset-graph-btn" type="button" class="btn btn-sm btn-outline">
                        Reset
                    </button>
                </div>
            </div>

            {% if document.graph_data and document.graph_data.nodes %}
            <div class="flex-1 min-h-0">
                <div id="graph-view" class="h-full w-full rounded-xl border border-base-300 bg-slate-900"></div>
            </div>

            <div class="mt-4 flex flex-wrap gap-2 text-xs">
                <span class="badge bg-transparent text-[#60a5fa] border-[#60a5fa]">Person</span>
                <span class="badge bg-transparent text-[#34d399] border-[#34d399]">Location</span>
                <span class="badge bg-transparent text-[#fbbf24] border-[#fbbf24]">Organization</span>
                <span class="badge bg-transparent text-[#9ca3af] border-[#9ca3af]">Concept</span>
            </div>

            <div class="mt-4 rounded-xl border border-base-300 bg-base-200/20 p-4 text-sm opacity-80">
                Click a node or edge to inspect graph evidence.
            </div>
            {% else %}
            <div
                class="mt-4 flex h-full min-h-[500px] items-center justify-center rounded-xl border border-dashed border-base-300 bg-base-200/40">
                <div class="text-center">
                    <p class="font-medium">No graph data available</p>
                    <p class="mt-2 text-sm opacity-70">
                        Process the document first to generate the graph.
                    </p>
                </div>
            </div>
            {% endif %}
        </div>
    </section>
</div>
{% include "document_manager/components/graph_panel_script.jinja" %}