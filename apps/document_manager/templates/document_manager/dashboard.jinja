{% extends "document_manager/base.jinja" %}


{% block title %}
Dashboard
{% endblock %}


{% block content %}

<div class="flex justify-between items-center mb-8">

    <div>

        <h1 class="text-3xl font-bold">
            Documents
        </h1>

        <p class="text-sm opacity-70">
            Manage and explore your knowledge graph documents
        </p>

    </div>


    <button
        class="btn btn-primary"
        hx-get="{{url('document_manager:upload_document')}}"
        hx-target="#modal-container"
        hx-swap="innerHTML"
    >
        Upload Document
    </button>

</div>


<!-- Document table -->

<div
    id="document-table-container"
    hx-get="{{url('document_manager:document_table')}}"
    hx-trigger="load, documentsUpdated from:body"
    hx-swap="innerHTML"
>
</div>

<div class="mt-10 card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body">
        <h2 class="card-title">Ask The Graph</h2>

        <form
            class="space-y-4"
            hx-post="/document/api/ask-question/0"
            hx-target="#qa-result"
            hx-swap="innerHTML"
            hx-on:htmx:config-request="event.detail.path = '/document/api/ask-question/' + this.querySelector('[name=doc_id]').value">
            <div>
                <label class="label">
                    <span class="label-text">Document ID</span>
                </label>
                <input type="number" name="doc_id" class="input input-bordered w-full" placeholder="Enter document id" required/>
            </div>

            <div>
                <label class="label">
                    <span class="label-text">Question</span>
                </label>
                <textarea
                    name="question"
                    class="textarea textarea-bordered w-full"
                    rows="4"
                    placeholder="Example: Who works at OpenAI?"
                    required
                ></textarea>
            </div>

            <button class="btn btn-secondary" type="submit">
                Ask
            </button>
        </form>

        <div id="qa-result"></div>
    </div>
</div>


<!-- Modal target -->

<div id="modal-container"></div>

<script>

document.body.addEventListener("closeUploadModal", function () {
    const modal = document.getElementById("upload-modal")
    if (modal) { modal.remove()}
})

</script>

{% endblock %}