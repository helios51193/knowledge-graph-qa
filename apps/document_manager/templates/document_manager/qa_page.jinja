{% extends "document_manager/base.jinja" %}

{% block title %}
QA - {{ document.name }}
{% endblock %}

{% block content %}
<p class="text-sm opacity-70">
    {{ session.title or "Untitled Conversation" }}
</p>
<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-3xl font-bold">Document QA</h1>
        <p class="text-sm opacity-70">
            Ask questions about "{{ document.name }}"
        </p>
    </div>

    <a href="{{ url('document_manager:dashboard') }}" class="btn btn-outline">
        Back To Dashboard
    </a>
</div>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <section class="card border border-base-300 bg-base-100 shadow-sm h-[78vh] min-h-[78vh]">
        <div class="card-body p-0 flex h-full min-h-0 flex-col">
            <div class="border-b border-base-300 px-6 py-4">
                <h2 class="text-lg font-semibold">Conversation</h2>
                <p class="text-sm opacity-70">
                    Ask questions about the extracted graph for this document
                </p>
            </div>
            <div id="qa-thread" class="flex-1 min-h-0 space-y-4 overflow-y-auto px-6 py-6">
                {% if qa_messages %}
                {% for message in qa_messages %}
                {% if message.role == "user" %}
                <div class="chat chat-end">
                    <div class="chat-bubble chat-bubble-primary">
                        {{ message.content }}
                    </div>
                </div>
                {% else %}
                <div class="chat chat-start">
                    <div class="chat-bubble bg-base-200 text-base-content max-w-full">
                        <div>{{ message.content }}</div>
                        {% if message.cypher or message.query_rows or message.provenance %}
                            <div class="mt-3">
                                <button
                                    type="button"
                                    class="btn btn-xs btn-outline"
                                    onclick="openAnswerExplainModal(this)"
                                >
                                    Explain Answer
                                </button>

                                <script type="application/json" class="qa-explain-data">
                                    {{ {
                                        "cypher": message.cypher,
                                        "rows": message.query_rows,
                                        "provenance": message.provenance,
                                        "question_analysis": message.question_analysis
                                    } | tojson }}
                                </script>
                            </div>
                        {% endif %}
                    </div>
                </div>
                {% endif %}
                {% endfor %}
                {% else %}
                <div class="chat chat-start">
                    <div class="chat-bubble bg-base-200 text-base-content">
                        Ask a question to begin exploring this document's graph.
                    </div>
                </div>
                {% endif %}
            </div>


            <div class="border-t border-base-300 px-6 py-4">
                <form
                    id="qa-ask-form" class="space-y-3"
                    hx-post="{{ url('document_manager:ask_question', kwargs={'doc_id': document.id, 'session_id': session.id}) }}"
                    hx-target="#qa-thread"
                    hx-swap="beforeend">
                    {% csrf_token %}

                    <textarea name="question" class="textarea textarea-bordered w-full" rows="3"
                        placeholder="Ask something like: What can you tell me about Whisperwood?" required></textarea>

                    <div class="flex justify-end">
                        <button id="qa-ask-button" class="btn btn-primary" type="submit">
                            <span class="qa-ask-label">Ask</span>
                            <span id="qa-ask-spinner" class="loading loading-spinner loading-xs hidden"></span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>
    {% include "document_manager/components/graph_panel.jinja" %}

</div>
<dialog id="graph-evidence-modal" class="modal">
    <div class="modal-box max-w-4xl">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h3 id="graph-evidence-title" class="text-xl font-semibold">Graph Evidence</h3>
                <p id="graph-evidence-meta" class="mt-1 text-sm opacity-70"></p>
            </div>

            <form method="dialog">
                <button class="btn btn-sm btn-outline">Close</button>
            </form>
        </div>

        <div
            id="graph-evidence-body"
            class="mt-6 max-h-[65vh] overflow-y-auto rounded-xl border border-base-300 bg-base-200/30 p-4 whitespace-pre-wrap text-sm"
        ></div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>
<dialog id="answer-explain-modal" class="modal">
    <div class="modal-box max-w-6xl">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h3 class="text-xl font-semibold">Answer Explainability</h3>
                <p class="mt-1 text-sm opacity-70">
                    Query details and supporting source evidence
                </p>
            </div>

            <form method="dialog">
                <button class="btn btn-sm btn-outline">Close</button>
            </form>
        </div>

        <div class="mt-6 grid grid-cols-1 gap-6 lg:grid-cols-2">
            <div class="space-y-4">
                <div>
                    <h4 class="font-semibold">Question Analysis</h4>
                    <pre id="answer-explain-question-analysis" class="mt-2 max-h-[18vh] overflow-auto rounded-xl bg-base-200/50 p-4 text-xs"></pre>
                </div>
                <div>
                    <h4 class="font-semibold">Cypher Query</h4>
                    <pre id="answer-explain-cypher" class="mt-2 max-h-[28vh] overflow-auto rounded-xl bg-base-200/50 p-4 text-xs"></pre>
                </div>

                <div>
                    <h4 class="font-semibold">Query Result</h4>
                    <pre id="answer-explain-rows" class="mt-2 max-h-[28vh] overflow-auto rounded-xl bg-base-200/50 p-4 text-xs"></pre>
                </div>
            </div>

            <div>
                <h4 class="font-semibold">Source Evidence</h4>
                <div id="answer-explain-provenance" class="mt-2 max-h-[58vh] overflow-y-auto space-y-3 rounded-xl border border-base-300 bg-base-200/30 p-4"></div>
            </div>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>
<script>
window.lastGraphHighlightPayload = window.lastGraphHighlightPayload || null;

function escapeHtml(value) {
    return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
}

window.openGraphEvidenceModal = function (title, meta, sourceText) {
    const modal = document.getElementById("graph-evidence-modal");
    const titleEl = document.getElementById("graph-evidence-title");
    const metaEl = document.getElementById("graph-evidence-meta");
    const bodyEl = document.getElementById("graph-evidence-body");

    if (!modal || !titleEl || !metaEl || !bodyEl) {
        return;
    }

    titleEl.textContent = title || "Graph Evidence";
    metaEl.textContent = meta || "";
    bodyEl.textContent = sourceText || "No source text available.";

    modal.showModal();
};

window.openGraphEvidenceModalForNode = function (nodeData) {
    const provenance = nodeData.provenance || {};
    const sourceText = provenance.source_text || "No source text available.";

    const meta = `Chunk ${provenance.chunk_id ?? "-"} | ${provenance.start_index ?? "-"} - ${provenance.end_index ?? "-"}`;
    const title = `${nodeData.name} (${nodeData.label})`;

    window.openGraphEvidenceModal(title, meta, sourceText);
};

window.openGraphEvidenceModalForEdge = function (edgeData) {
    const provenance = edgeData.provenance || {};
    const sourceText = provenance.source_text || "No source text available.";

    const meta = `Chunk ${provenance.chunk_id ?? "-"} | ${provenance.start_index ?? "-"} - ${provenance.end_index ?? "-"}`;
    const title = `${edgeData.source_name} -[${edgeData.type}]-> ${edgeData.target_name}`;

    window.openGraphEvidenceModal(title, meta, sourceText);
};

window.openAnswerExplainModal = function (buttonEl) {
    const scriptEl = buttonEl.parentElement.querySelector(".qa-explain-data");

    if (!scriptEl) {
        return;
    }

    let data = {};
    try {
        data = JSON.parse(scriptEl.textContent || "{}");
    } catch (error) {
        console.error("Failed to parse explainability payload", error);
        return;
    }

    const modal = document.getElementById("answer-explain-modal");
    const cypherEl = document.getElementById("answer-explain-cypher");
    const rowsEl = document.getElementById("answer-explain-rows");
    const provenanceEl = document.getElementById("answer-explain-provenance");
    const questionAnalysisEl = document.getElementById("answer-explain-question-analysis");

    if (!modal || !questionAnalysisEl || !cypherEl || !rowsEl || !provenanceEl) {
        return;
    }

    questionAnalysisEl.textContent = JSON.stringify(data.question_analysis || {}, null, 2);
    cypherEl.textContent = data.cypher || "No Cypher available.";
    rowsEl.textContent = JSON.stringify(data.rows || [], null, 2);

    const provenance = data.provenance || [];
    if (!provenance.length) {
        provenanceEl.innerHTML = '<div class="text-sm opacity-70">No source evidence available.</div>';
    } else {
        provenanceEl.innerHTML = provenance.map(item => `
            <div class="rounded-xl bg-base-300/40 p-3 text-xs">
                <div class="font-semibold">${escapeHtml(item.title || "Evidence")}</div>
                <div class="mt-1 opacity-70">
                    Chunk ${escapeHtml(item.chunk_id ?? "-")}
                    ${item.start_index != null && item.end_index != null
                        ? `| ${escapeHtml(item.start_index)} - ${escapeHtml(item.end_index)}`
                        : ""}
                </div>
                <div class="mt-2 whitespace-pre-wrap text-sm">
                    ${escapeHtml(item.snippet || item.source_text || "")}
                </div>
            </div>
        `).join("");
    }

    modal.showModal();
};

document.body.addEventListener("qaGraphHighlight", function (event) {
    window.lastGraphHighlightPayload = event.detail || {};

    if (window.documentGraphCy && typeof window.applyDocumentGraphHighlight === "function") {
        window.applyDocumentGraphHighlight(window.lastGraphHighlightPayload);
    }
});

(function () {
    const qaThread = document.getElementById("qa-thread");
    const qaAskForm = document.getElementById("qa-ask-form");
    const qaAskButton = document.getElementById("qa-ask-button");
    const qaAskSpinner = document.getElementById("qa-ask-spinner");
    const qaAskLabel = qaAskButton ? qaAskButton.querySelector(".qa-ask-label") : null;
    const qaAskTextarea = qaAskForm ? qaAskForm.querySelector('textarea[name="question"]') : null;

    function scrollQaThreadToBottom() {
        if (!qaThread) {
            return;
        }

        qaThread.scrollTop = qaThread.scrollHeight;
    }

    function setAskLoading(isLoading) {
        if (qaAskButton) {
            qaAskButton.disabled = isLoading;
        }

        if (qaAskTextarea) {
            qaAskTextarea.disabled = isLoading;
        }

        if (qaAskSpinner) {
            qaAskSpinner.classList.toggle("hidden", !isLoading);
        }

        if (qaAskLabel) {
            qaAskLabel.textContent = isLoading ? "Asking..." : "Ask";
        }
    }

    if (qaAskForm) {
        qaAskForm.addEventListener("htmx:beforeRequest", function () {
            setAskLoading(true);
        });

        qaAskForm.addEventListener("htmx:afterRequest", function () {
            setAskLoading(false);
        });

        qaAskForm.addEventListener("htmx:responseError", function () {
            setAskLoading(false);
        });
    }

    document.body.addEventListener("htmx:afterSwap", function (event) {
        if (event.target && event.target.id === "qa-thread") {
            scrollQaThreadToBottom();

            if (qaAskTextarea) {
                qaAskTextarea.value = "";
                qaAskTextarea.focus();
            }
        }
    });

    window.addEventListener("load", function () {
        scrollQaThreadToBottom();
    });
})();
</script>

{% endblock %}